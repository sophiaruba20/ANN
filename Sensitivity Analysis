# sensitivity_analysis.py

import pandas as pd
import matplotlib.pyplot as plt

data = pd.read_csv("dataset.csv")

inputs = ['Cement','FA','CA','Water','GP','GF']

for column in inputs:

    plt.scatter(data[column], data['Compressive_Strength'])

    plt.xlabel(column)
    plt.ylabel("Compressive Strength")

    plt.title(f"Sensitivity Analysis: {column}")

    plt.show()
